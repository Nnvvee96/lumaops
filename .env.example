# LumaOps local development environment.
# Copy this file to `.env` and fill in any provider tokens.
# `.env` is gitignored; `.env.example` is committed.

# ============================================================
# Database
# ============================================================
# Points at the docker-compose postgres service on host port 5433.
DATABASE_URL=postgres://lumaops:lumaops@localhost:5433/lumaops

# ============================================================
# Operator identity (MVP — single-user mode, Decision O)
# ============================================================
LUMAOPS_OPERATOR_NAME=Operator

# ============================================================
# Connectors — tokens land here as connectors ship.
# ============================================================
# GitHub Personal Access Token — needed for the GitHub Connector
# (validateCredentials / health from S4B; full sync from S4C).
# Required scopes: repo, read:user. Generate at:
#   https://github.com/settings/tokens
# Token never reaches DB or logs — only its sha256 fingerprint is persisted.
# LUMAOPS_GITHUB_TOKEN=ghp_xxxxx
