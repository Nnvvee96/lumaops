{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm -r typecheck)",
      "Bash(pnpm -r --if-present typecheck)",
      "Bash(pnpm -r lint)",
      "Bash(pnpm -r --if-present lint)",
      "Bash(pnpm -r test)",
      "Bash(pnpm -r --if-present test)",
      "Bash(pnpm --filter @lumaops/web typecheck)",
      "Bash(pnpm --filter @lumaops/web lint)",
      "Bash(pnpm --filter @lumaops/core typecheck)",
      "Bash(pnpm --filter @lumaops/ui typecheck)",
      "Bash(pnpm --filter @lumaops/connectors typecheck)",
      "Bash(pnpm --filter @lumaops/core db:generate)",
      "Bash(pnpm install)",
      "Bash(gh pr checks *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh repo view *)",
      "Bash(gh auth status)"
    ]
  }
}
