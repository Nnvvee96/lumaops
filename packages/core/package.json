{
  "name": "@lumaops/core",
  "version": "0.0.0",
  "private": true,
  "description": "LumaOps domain types, freshness logic, error classifier, metric registry.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/schema": "./src/db/schema.ts",
    "./db/client": "./src/db/client.ts",
    "./freshness": "./src/freshness/index.ts",
    "./metrics": "./src/metrics/index.ts",
    "./connectors": "./src/connectors/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:demo": "tsx src/db/seed-demo.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
